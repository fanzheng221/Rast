{
  "name": "@rust_ast/unplugin",
  "version": "0.1.0",
  "description": "Universal bundler plugin for Rast AST analysis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fanzheng221/Rast.git",
    "directory": "packages/unplugin"
  },
  "homepage": "https://github.com/fanzheng221/Rast/tree/main/packages/unplugin#readme",
  "bugs": {
    "url": "https://github.com/fanzheng221/Rast/issues"
  },
  "keywords": [
    "rast",
    "ast",
    "vite",
    "webpack",
    "unplugin"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vite": ">=3.0.0",
    "webpack": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "dependencies": {
    "@rust_ast/bindings": "workspace:*",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsup": "^8.3.5",
    "typescript": "^5.9.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}

{
  "name": "rast-bindings",
  "version": "0.1.0",
  "description": "NAPI bindings for Rast AST engine",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "rast-bindings",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-pc-windows-msvc",
        "aarch64-pc-windows-msvc",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node test/index.mjs"
  },
  "dependencies": {
    "@napi-rs/cli": "^2.18.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2"
  }
}

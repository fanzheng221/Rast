{
  "name": "@rust_ast/bindings",
  "version": "0.1.0",
  "description": "NAPI bindings for Rast AST engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fanzheng221/Rast.git",
    "directory": "packages/bindings"
  },
  "homepage": "https://github.com/fanzheng221/Rast/tree/main/packages/bindings#readme",
  "bugs": {
    "url": "https://github.com/fanzheng221/Rast/issues"
  },
  "keywords": [
    "rast",
    "ast",
    "napi",
    "rust"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "napi": {
    "binaryName": "rast-bindings",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node test/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@napi-rs/cli": "^3.5.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.2"
  }
}

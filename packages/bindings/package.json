{
  "name": "@rust_ast/bindings",
  "version": "0.1.0",
  "description": "NAPI bindings for Rast AST engine",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "napi": {
    "binaryName": "rast-bindings",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node test/index.mjs"
  },
  "dependencies": {
    "@napi-rs/cli": "^3.5.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.2"
  }
}
